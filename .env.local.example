# .env.local — Local build configuration (not committed to git)
#
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# These values are read by scripts/build.sh when building the HomeKitHelper
# Catalyst app, which requires Apple Developer signing.

# Your Apple Developer Team ID (found in Xcode → Settings → Accounts → Team ID)
HOMEKIT_TEAM_ID=

# Optional: Override the signing identity (defaults to "Apple Development")
# SIGNING_IDENTITY=Apple Development
